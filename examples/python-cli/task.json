{
  "project": "python-todo-cli",
  "description": "A Python CLI tool for managing a todo list using SQLite",
  "environment": {
    "sdk": "python",
    "install_cmd": "pip install -r requirements.txt",
    "lint_cmd": "ruff check .",
    "test_cmd": "pytest",
    "build_cmd": "python -m py_compile **/*.py"
  },
  "tasks": [
    {
      "id": 1,
      "title": "Project Setup",
      "category": "infrastructure",
      "description": "Initialize Python project with basic structure",
      "steps": [
        "Create project directory structure",
        "Create requirements.txt with dependencies",
        "Initialize git repository",
        "Create .gitignore"
      ],
      "passes": false
    },
    {
      "id": 2,
      "title": "Database Setup",
      "category": "infrastructure",
      "description": "Set up SQLite database and models",
      "steps": [
        "Create database.py with SQLite connection",
        "Define Todo model",
        "Create tables on startup",
        "Test database connection"
      ],
      "passes": false
    },
    {
      "id": 3,
      "title": "CLI Framework",
      "category": "feature",
      "description": "Set up Click CLI framework",
      "steps": [
